{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "lib": [
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": [
        "types/*.d.ts",
        "src/**/*.ts"
    ]
}
